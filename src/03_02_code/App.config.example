<?xml version="1.0" encoding="utf-8" ?>
<!--
  Copy this file to App.config and fill in your API keys.
  App.config is listed in .gitignore so your real keys are never committed.

  To get keys:
    OpenAI:      https://platform.openai.com/api-keys
    OpenRouter:  https://openrouter.ai/settings/keys
-->
<configuration>
  <appSettings>
    <!-- ======================================================
         AI Provider selection
         Set to "openai" or "openrouter".
         If both keys are present, defaults to "openai".
         ====================================================== -->
    <add key="AI_PROVIDER" value="" />

    <!-- OpenAI API key (sk-…) -->
    <add key="OPENAI_API_KEY" value="" />

    <!-- OpenRouter API key (sk-or-v1-…) -->
    <add key="OPENROUTER_API_KEY" value="" />

    <!-- Optional: sent as HTTP-Referer when using OpenRouter -->
    <add key="OPENROUTER_HTTP_REFERER" value="" />

    <!-- Optional: sent as X-Title when using OpenRouter -->
    <add key="OPENROUTER_APP_NAME" value="" />

    <!-- Gemini API key – required only for Lesson 04 audio/video examples -->
    <add key="GEMINI_API_KEY" value="" />

    <!-- ======================================================
         03_02_code: Code execution agent settings
         ====================================================== -->

    <!-- Permission level for Deno sandbox: safe | standard | network | full -->
    <add key="PERMISSION_LEVEL" value="standard" />

    <!-- Model to use for the agent (default: gpt-4.1) -->
    <add key="OPENAI_MODEL" value="gpt-4.1" />
  </appSettings>
</configuration>
