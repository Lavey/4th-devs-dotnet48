<?xml version="1.0" encoding="utf-8" ?>
<!--
  Copy this file to App.config (in this project's folder) and fill in your keys.
  App.config is listed in .gitignore so your real credentials are never committed.

  AI providers:
    OpenAI:      https://platform.openai.com/api-keys
    OpenRouter:  https://openrouter.ai/settings/keys

  Neo4j:
    Run Neo4j 5.11+ with vector index support:
      docker run -d --name neo4j -p 7474:7474 -p 7687:7687 \
        -e NEO4J_AUTH=neo4j/password neo4j:5
-->
<configuration>
  <appSettings>
    <!-- ======================================================
         AI Provider selection
         Set to "openai" or "openrouter".
         If both keys are present, defaults to "openai".
         ====================================================== -->
    <add key="AI_PROVIDER" value="" />

    <!-- OpenAI API key (sk-…) -->
    <add key="OPENAI_API_KEY" value="" />

    <!-- OpenRouter API key (sk-or-v1-…) -->
    <add key="OPENROUTER_API_KEY" value="" />

    <!-- Optional: sent as HTTP-Referer when using OpenRouter -->
    <add key="OPENROUTER_HTTP_REFERER" value="" />

    <!-- Optional: sent as X-Title when using OpenRouter -->
    <add key="OPENROUTER_APP_NAME" value="" />

    <!-- ======================================================
         Neo4j connection
         ====================================================== -->
    <add key="NEO4J_URI"      value="bolt://localhost:7687" />
    <add key="NEO4J_USERNAME" value="neo4j" />
    <add key="NEO4J_PASSWORD" value="password" />
  </appSettings>
</configuration>
