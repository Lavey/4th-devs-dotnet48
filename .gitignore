StyleCopReport.xml

# Roslyn cache
*.cache

# Node / npm (if any JS tools are mixed in)
node_modules/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Sensitive / local config – never commit real keys
App.config
